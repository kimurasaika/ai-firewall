# Staging environment — copy to .env.staging (never commit)
# Same structure as .env.example with staging-specific values

ENVIRONMENT=staging
SECRET_MANAGER=env

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=staging-redis-password-change-me
REDIS_TLS=true
REDIS_TLS_CA=/app/certs/ca.crt
REDIS_TLS_CERT=/app/certs/redis/client.crt
REDIS_TLS_KEY=/app/certs/redis/client.key

DATABASE_URL=postgresql+asyncpg://dlp_user:staging-db-password@timescaledb:5432/dlp_audit
TIMESCALEDB_PASSWORD=staging-db-password-change-me

MTLS_CA_CERT=/app/certs/ca.crt
MTLS_CERT_DIR=/app/certs/mtls

ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8443
ORCHESTRATOR_WORKERS=4

DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=9443
DASHBOARD_API_KEY=staging-dashboard-api-key
ADMIN_JWT_SECRET=staging-jwt-secret-min-32-chars!!!!!
ADMIN_JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_TOTP_SECRET=

MITMPROXY_CA_CERT=/app/certs/ca.crt
MITMPROXY_CA_KEY=/app/certs/ca.key

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/STAGING/WEBHOOK/URL
SMTP_HOST=smtp.company.local
SMTP_PORT=587
SMTP_USERNAME=dlp-staging@company.local
SMTP_PASSWORD=staging-smtp-password
ALERT_FROM=dlp-staging@company.local
ALERT_TO=it-admin@company.local

OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
LOKI_URL=http://loki:3100
VICTORIAMETRICS_URL=http://victoriametrics:8428
LOG_LEVEL=INFO

PROXY_LISTEN_HOST=0.0.0.0
PROXY_LISTEN_PORT=8888

HAPROXY_STATS_PASSWORD=staging-haproxy-stats
GRAFANA_ADMIN_PASSWORD=staging-grafana-password
